# Normalize line endings: store everything as LF in the repo.
# Critical for deploy/ shell scripts + systemd units that run on Linux.
* text=auto eol=lf

# Explicit LF for files that must stay LF regardless of platform.
*.sh        text eol=lf
*.service   text eol=lf
*.timer     text eol=lf
*.yaml      text eol=lf
*.py        text eol=lf

# Binary assets — never touch.
*.png binary
*.ico binary
*.woff2 binary
